{
    "schemaVersion": 1,
    "id": "mediatoast",
    "version": "${version}",
    "name": "MediaToast",
    "description": "Current playing media info via the vanilla music toast (previously MprisToast)",
    "authors": ["technicfan"],
    "contact": {
        "sources": "https://github.com/technicfan/MediaToast"
    },
    "license": "MIT",
    "icon": "assets/mediatoast/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": ["technicfan.mediatoast.MediaToastClient"]
    },
    "mixins": ["mediatoast.mixins.json"],
    "depends": {
        "fabricloader": ">=0.17.3",
        "minecraft": "${minecraft}",
        "java": ">=21",
        "fabric-api": "*"
    }
}
